{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "highlevel.ai" }],
      "destination": "https://www.highlevel.ai/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/extract-earnings.js": {
      "maxDuration": 30
    },
    "api/pipeline-webhook.js": {
      "maxDuration": 15
    },
    "api/update-video.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://www.highlevel.ai" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
